{
  "name": "reluctocracy",
  "version": "0.0.0",
  "description": "Reference implementation scaffold for the Reluctocracy protocol.",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "tsc --noEmit",
    "lint": "eslint .",
    "simulate:live-credence": "vitest run test/live-capture-credence.test.ts",
    "test": "vitest run --passWithNoTests",
    "verify": "npm run build && npm run lint && npm run test"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@noble/ed25519": "^3.0.0",
    "@noble/hashes": "^2.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.3",
    "eslint": "^10.5.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.61.0",
    "vitest": "^4.1.8"
  }
}
